# Copy this file to .env and fill in your values.
# .env is never committed — it stays local to your machine.

# Required: destination folder inside your cloud storage
# CLOUD_DIR="$HOME/Library/CloudStorage/ProtonDrive-you@example.com-folder/ios_backups"
# CLOUD_DIR="$HOME/Library/CloudStorage/OneDrive-Personal/ios_backups"
# CLOUD_DIR="$HOME/Library/CloudStorage/GoogleDrive-you@example.com/My Drive/ios_backups"
# CLOUD_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/ios_backups"
# CLOUD_DIR="$HOME/Dropbox/ios_backups"
# CLOUD_DIR="/Volumes/MyNAS/ios_backups"

# Optional overrides (defaults shown)
# KEEP_LAST=5
# MAX_BACKUP_AGE_DAYS=7
# SPLIT_SIZE=5g
# PAR2_REDUNDANCY=15
# LOG_FILE="$HOME/Library/Logs/backup_ios.log"
